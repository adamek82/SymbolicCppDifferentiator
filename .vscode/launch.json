{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Differentiator",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/diff.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;${env:PATH}"
                },
                {
                    "name": "Path",
                    "value": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;${env:Path}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "Build Debug",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set PATH for MSYS2/UCRT64 DLLs",
                    "text": "set environment PATH=C:/msys64/ucrt64/bin;C:/msys64/usr/bin",
                    "ignoreFailures": true
                }
            ],
            "linux": {
                "program": "${workspaceFolder}/build/debug/diff",
                "miDebuggerPath": "/usr/bin/gdb",
                "environment": [],
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            }
        }
    ]
}
